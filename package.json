{
  "name": "poster",
  "version": "1.0.0",
  "description": "A4 landscape page poster project with TypeScript and CSS",
  "main": "index.js",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:ci && npm run test:e2e",
    "test:unit": "vitest",
    "test:ci": "vitest run",
