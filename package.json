    "report": "playwright show-report",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "keywords": [
    "a4",
    "poster"
  ],
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.60.0",
