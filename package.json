    "@vitest/ui": "4.1.6",
    "eslint": "10.4.0",
    "http-server": "14.1.1",
    "jsdom": "29.1.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "i18next": "26.2.0",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-http-backend": "4.0.0"
  }
